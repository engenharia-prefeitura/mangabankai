{
  "buildCommand": "node build-lite.cjs && node build-home.cjs && node build-ssg.cjs && node build-sitemap.cjs",
  "outputDirectory": ".",
  "framework": null,
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/manga/:id/:cap", "destination": "/reader.html?manga=:id&cap=:cap" },
    { "source": "/resolve-chapter", "destination": "/api/resolve-chapter" },
    { "source": "/api/auth/:action", "destination": "/api/auth?action=:action" },
    { "source": "/api/admin/:action", "destination": "/api/admin?action=:action" },
    { "source": "/api/manga/:action", "destination": "/api/manga?action=:action" }
  ]
}
