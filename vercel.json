{
  "buildCommand": "node build-lite.cjs && node build-home.cjs && node build-home-prerender.cjs && node build-ssg.cjs && node build-sitemap.cjs",
  "outputDirectory": ".",
  "framework": null,
  "installCommand": "npm install",
  "functions": {
    "api/og-chapter.js": { "includeFiles": "{reader.html,js/manga-search.json}" }
  },
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/sitemap-:n.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/sitemap.xsl",
      "headers": [
        { "key": "Content-Type", "value": "text/xsl; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/manga/:id/:cap", "destination": "/api/og-chapter?manga=:id&cap=:cap" },
    { "source": "/resolve-chapter", "destination": "/api/resolve-chapter" },
    { "source": "/api/auth/:action", "destination": "/api/auth?action=:action" },
    { "source": "/api/admin/:action", "destination": "/api/admin?action=:action" },
    { "source": "/api/manga/:action", "destination": "/api/manga?action=:action" }
  ]
}
